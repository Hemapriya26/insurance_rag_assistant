### =========================================================
### Insurance Policy RAG Assistant — .gitignore
### =========================================================

# -------------------------------------------------------
# Environment / secrets — NEVER commit these
# -------------------------------------------------------
.env
.env.*
!.env.example
*.pem
*.key
secrets.toml
.streamlit/secrets.toml

# -------------------------------------------------------
# Python
# -------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
dist/
*.egg-info/
*.egg
MANIFEST

# -------------------------------------------------------
# Virtual environments
# -------------------------------------------------------
venv/
.venv/
env/
ENV/
env.bak/
venv.bak/

# -------------------------------------------------------
# Testing / linting / type-checking caches
# -------------------------------------------------------
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
.coverage.*
htmlcov/
.tox/

# -------------------------------------------------------
# Jupyter (in case notebooks are used for experimentation)
# -------------------------------------------------------
.ipynb_checkpoints/
*.ipynb_checkpoints

# -------------------------------------------------------
# Streamlit
# -------------------------------------------------------
# NOTE: .streamlit/config.toml (if present) is generally safe to commit —
# only secrets.toml should be excluded (already covered above).

# -------------------------------------------------------
# Project runtime data — generated at run time, not source code
# -------------------------------------------------------

# Uploaded PDFs (user data)
data/uploads/*
!data/uploads/.gitkeep

# FAISS vector index + persisted BM25 chunk cache
data/vectorstore/*
!data/vectorstore/.gitkeep
*.faiss
*.pkl

# Multi-conversation store (Phase 4 conversation_store.py)
data/conversations.json

# Application logs (utils/logger.py — rotating file handler)
logs/*
!logs/.gitkeep
*.log

# Exported conversation/evaluation reports, if ever saved to disk
# (currently generated in-memory for st.download_button, but ignored
# defensively in case a future change writes them to disk)
exports/
*.export.md
*.export.json
*.export.pdf

# -------------------------------------------------------
# Model / embedding cache (sentence-transformers, huggingface, torch)
# -------------------------------------------------------
.cache/
huggingface/
.huggingface/
*.bin
*.safetensors

# -------------------------------------------------------
# OS / editor cruft
# -------------------------------------------------------
.DS_Store
Thumbs.db
desktop.ini
.vscode/
.idea/
*.swp
*.swo

# -------------------------------------------------------
# Temporary files
# -------------------------------------------------------
*.tmp
*.temp
*.bak
*~
